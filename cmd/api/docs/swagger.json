                    "type": "integer"
                },
                "created_at": {
                    "type": "string"
                },
                "deleted_at": {
                    "description": "DeletedAt *gorm.DeletedAt `gorm:\"index\" json:\"deleted_at\"`",
                    "type": "string"
                },

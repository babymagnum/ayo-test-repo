{
	"info": {
		"name": "Ayo-Test API",
		"description": "API untuk manajemen tim sepakbola (technical test)\n\n## Auth\nSemua endpoint kecuali auth/login & auth/register memerlukan JWT token.\nSetelah login, token otomatis disimpan ke variable `token`.\n\nBase URL: `{{base_url}}`",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/v1/auth/register",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "register"]
						},
						"description": "Register akun baru. Role opsional, default 'user'."
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('token', json.data.token);",
									"    pm.collectionVariables.set('user_id', json.data.id.toString());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/v1/auth/login",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "login"]
						},
						"description": "Login. Token JWT otomatis tersimpan ke variable collection."
					}
				}
			]
		},
